<div class="card product-card h-100 shadow-sm border-0">
  <div class="position-relative">
    <img src="/images/<%= product.image %>" class="card-img-top product-img" alt="<%= product.name %>"
      onerror="this.src='https://via.placeholder.com/300x200?text=No+Image'">
    <% if (product.featured) { %>
      <span class="badge bg-warning text-dark position-absolute top-0 start-0 m-2">⭐ Featured</span>
    <% } %>
    <% if (product.originalPrice > product.price) { %>
      <span class="badge bg-danger position-absolute top-0 end-0 m-2">
        <%= Math.round((1 - product.price / product.originalPrice) * 100) %>% OFF
      </span>
    <% } %>
  </div>
  <div class="card-body d-flex flex-column">
    <span class="badge bg-light text-primary border border-primary mb-1" style="width: fit-content; font-size: 10px;"><%= product.category %></span>
    <h6 class="card-title fw-semibold text-truncate"><%= product.name %></h6>
    <div class="mt-auto">
      <div class="d-flex align-items-center gap-2 mb-2">
        <span class="fw-bold text-primary fs-6">₹<%= product.price.toLocaleString() %></span>
        <% if (product.originalPrice > product.price) { %>
          <small class="text-muted text-decoration-line-through">₹<%= product.originalPrice.toLocaleString() %></small>
        <% } %>
      </div>
      <div class="d-flex gap-2">
        <a href="/products/<%= product._id %>" class="btn btn-outline-primary btn-sm flex-grow-1">View</a>
        <form action="/cart/add/<%= product._id %>" method="POST" class="flex-grow-1">
          <button type="submit" class="btn btn-primary btn-sm w-100">
            <i class="fas fa-cart-plus"></i>
          </button>
        </form>
      </div>
    </div>
  </div>
</div>
