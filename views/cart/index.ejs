<%- include('../partials/header') %>

<div class="container py-5">
  <h3 class="fw-bold mb-4"><i class="fas fa-shopping-cart text-primary me-2"></i>My Cart</h3>

  <% if (cart.length === 0) { %>
    <div class="text-center py-5">
      <i class="fas fa-shopping-cart fa-5x text-muted mb-4"></i>
      <h4 class="text-muted">Your cart is empty!</h4>
      <a href="/products" class="btn btn-primary btn-lg mt-3 px-5">Start Shopping</a>
    </div>
  <% } else { %>
    <div class="row g-4">
      <div class="col-md-8">
        <div class="card border-0 shadow-sm">
          <div class="card-body">
            <% cart.forEach(item => { %>
              <div class="row align-items-center py-3 border-bottom">
                <div class="col-2">
                  <img src="/images/<%= item.image %>" class="img-fluid rounded" alt="<%= item.name %>"
                    onerror="this.src='https://via.placeholder.com/80x80?text=IMG'" style="height:70px; width:70px; object-fit:cover;">
                </div>
                <div class="col-4">
                  <h6 class="fw-semibold mb-1"><%= item.name %></h6>
                  <span class="text-primary fw-bold">₹<%= item.price.toLocaleString() %></span>
                </div>
                <div class="col-3">
                  <form action="/cart/update/<%= item.productId %>" method="POST" class="d-flex align-items-center gap-2">
                    <input type="number" name="quantity" value="<%= item.quantity %>" min="1" max="10"
                      class="form-control form-control-sm" style="width: 65px;" onchange="this.form.submit()">
                  </form>
                </div>
                <div class="col-2 text-end">
                  <span class="fw-bold">₹<%= (item.price * item.quantity).toLocaleString() %></span>
                </div>
                <div class="col-1 text-end">
                  <a href="/cart/remove/<%= item.productId %>" class="btn btn-sm btn-outline-danger"
                    onclick="return confirm('Remove this item?')">
                    <i class="fas fa-trash"></i>
                  </a>
                </div>
              </div>
            <% }); %>
          </div>
        </div>
      </div>

      <!-- Order Summary -->
      <div class="col-md-4">
        <div class="card border-0 shadow-sm">
          <div class="card-body">
            <h5 class="fw-bold mb-4">Order Summary</h5>
            <div class="d-flex justify-content-between mb-2">
              <span class="text-muted">Subtotal (<%= cart.length %> items)</span>
              <span>₹<%= total.toLocaleString() %></span>
            </div>
            <div class="d-flex justify-content-between mb-2">
              <span class="text-muted">Shipping</span>
              <span class="text-success"><%= total >= 499 ? 'FREE' : '₹49' %></span>
            </div>
            <hr>
            <div class="d-flex justify-content-between fw-bold fs-5 mb-4">
              <span>Total</span>
              <span class="text-primary">₹<%= (total >= 499 ? total : total + 49).toLocaleString() %></span>
            </div>
            <a href="/cart/checkout" class="btn btn-primary w-100 btn-lg fw-bold">
              <i class="fas fa-credit-card me-2"></i>Proceed to Checkout
            </a>
            <a href="/products" class="btn btn-outline-secondary w-100 mt-2">Continue Shopping</a>
          </div>
        </div>
      </div>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
