<%- include('../partials/header') %>

<div class="container-fluid py-4">
  <div class="row">
    <!-- Sidebar -->
    <div class="col-md-2">
      <div class="card border-0 shadow-sm">
        <div class="card-body p-3">
          <h6 class="fw-bold text-primary mb-3"><i class="fas fa-cog me-2"></i>Admin Panel</h6>
          <ul class="list-unstyled">
            <li class="mb-2"><a href="/admin" class="text-decoration-none text-muted"><i class="fas fa-tachometer-alt me-2"></i>Dashboard</a></li>
            <li class="mb-2"><a href="/admin/products" class="text-decoration-none text-muted"><i class="fas fa-box me-2"></i>Products</a></li>
            <li class="mb-2"><a href="/admin/orders" class="text-decoration-none text-muted"><i class="fas fa-shopping-bag me-2"></i>Orders</a></li>
            <li class="mb-2"><a href="/admin/users" class="text-decoration-none text-dark fw-semibold"><i class="fas fa-users me-2 text-primary"></i>Users</a></li>
            <li class="mb-2"><a href="/" class="text-decoration-none text-muted"><i class="fas fa-store me-2"></i>View Store</a></li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="col-md-10">
      <h4 class="fw-bold mb-4">Manage Users</h4>

      <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>#</th>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Role</th>
                  <th>Joined</th>
                </tr>
              </thead>
              <tbody>
                <% if (users.length === 0) { %>
                  <tr><td colspan="5" class="text-center py-4 text-muted">No users found.</td></tr>
                <% } %>
                <% users.forEach((u, i) => { %>
                  <tr>
                    <td><%= i + 1 %></td>
                    <td>
                      <div class="d-flex align-items-center gap-2">
                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold"
                          style="width:35px; height:35px; font-size:14px;">
                          <%= u.name.charAt(0).toUpperCase() %>
                        </div>
                        <span class="fw-semibold"><%= u.name %></span>
                      </div>
                    </td>
                    <td class="text-muted"><%= u.email %></td>
                    <td>
                      <% if (u.isAdmin) { %>
                        <span class="badge bg-danger">Admin</span>
                      <% } else { %>
                        <span class="badge bg-light text-dark border">Customer</span>
                      <% } %>
                    </td>
                    <td><small class="text-muted"><%= new Date(u.createdAt).toLocaleDateString('en-IN') %></small></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
