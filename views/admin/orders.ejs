<%- include('../partials/header') %>

<div class="container-fluid py-4">
  <div class="row">
    <!-- Sidebar -->
    <div class="col-md-2">
      <div class="card border-0 shadow-sm">
        <div class="card-body p-3">
          <h6 class="fw-bold text-primary mb-3"><i class="fas fa-cog me-2"></i>Admin Panel</h6>
          <ul class="list-unstyled">
            <li class="mb-2"><a href="/admin" class="text-decoration-none text-muted"><i class="fas fa-tachometer-alt me-2"></i>Dashboard</a></li>
            <li class="mb-2"><a href="/admin/products" class="text-decoration-none text-muted"><i class="fas fa-box me-2"></i>Products</a></li>
            <li class="mb-2"><a href="/admin/orders" class="text-decoration-none text-dark fw-semibold"><i class="fas fa-shopping-bag me-2 text-primary"></i>Orders</a></li>
            <li class="mb-2"><a href="/admin/users" class="text-decoration-none text-muted"><i class="fas fa-users me-2"></i>Users</a></li>
            <li class="mb-2"><a href="/" class="text-decoration-none text-muted"><i class="fas fa-store me-2"></i>View Store</a></li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="col-md-10">
      <h4 class="fw-bold mb-4">Manage Orders</h4>

      <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>Order ID</th>
                  <th>Customer</th>
                  <th>Items</th>
                  <th>Total</th>
                  <th>Status</th>
                  <th>Date</th>
                  <th>Update</th>
                </tr>
              </thead>
              <tbody>
                <% if (orders.length === 0) { %>
                  <tr><td colspan="7" class="text-center py-4 text-muted">No orders yet.</td></tr>
                <% } %>
                <% orders.forEach(order => { %>
                  <tr>
                    <td><small class="fw-semibold">#<%= order._id.toString().slice(-8).toUpperCase() %></small></td>
                    <td>
                      <span class="fw-semibold"><%= order.user ? order.user.name : 'Deleted User' %></span><br>
                      <small class="text-muted"><%= order.user ? order.user.email : '' %></small>
                    </td>
                    <td><span class="badge bg-light text-dark border"><%= order.items.length %> item(s)</span></td>
                    <td class="fw-bold text-primary">₹<%= order.totalAmount.toLocaleString() %></td>
                    <td>
                      <span class="badge
                        <%= order.status === 'Delivered' ? 'bg-success' :
                           order.status === 'Shipped' ? 'bg-info' :
                           order.status === 'Processing' ? 'bg-warning text-dark' :
                           order.status === 'Cancelled' ? 'bg-danger' : 'bg-secondary' %>">
                        <%= order.status %>
                      </span>
                    </td>
                    <td><small><%= new Date(order.createdAt).toLocaleDateString('en-IN') %></small></td>
                    <td>
                      <form action="/admin/orders/status/<%= order._id %>" method="POST" class="d-flex gap-1">
                        <select name="status" class="form-select form-select-sm" style="width:130px;">
                          <% ['Pending','Processing','Shipped','Delivered','Cancelled'].forEach(s => { %>
                            <option value="<%= s %>" <%= order.status === s ? 'selected' : '' %>><%= s %></option>
                          <% }); %>
                        </select>
                        <button type="submit" class="btn btn-sm btn-primary">✓</button>
                      </form>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
