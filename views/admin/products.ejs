<%- include('../partials/header') %>

<div class="container-fluid py-4">
  <div class="row">
    <!-- Sidebar -->
    <div class="col-md-2">
      <div class="card border-0 shadow-sm">
        <div class="card-body p-3">
          <h6 class="fw-bold text-primary mb-3"><i class="fas fa-cog me-2"></i>Admin Panel</h6>
          <ul class="list-unstyled">
            <li class="mb-2"><a href="/admin" class="text-decoration-none text-muted"><i class="fas fa-tachometer-alt me-2"></i>Dashboard</a></li>
            <li class="mb-2"><a href="/admin/products" class="text-decoration-none text-dark fw-semibold"><i class="fas fa-box me-2 text-primary"></i>Products</a></li>
            <li class="mb-2"><a href="/admin/orders" class="text-decoration-none text-muted"><i class="fas fa-shopping-bag me-2"></i>Orders</a></li>
            <li class="mb-2"><a href="/admin/users" class="text-decoration-none text-muted"><i class="fas fa-users me-2"></i>Users</a></li>
            <li class="mb-2"><a href="/" class="text-decoration-none text-muted"><i class="fas fa-store me-2"></i>View Store</a></li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="col-md-10">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">Manage Products</h4>
        <a href="/admin/products/add" class="btn btn-primary">
          <i class="fas fa-plus me-2"></i>Add New Product
        </a>
      </div>

      <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>Image</th>
                  <th>Name</th>
                  <th>Category</th>
                  <th>Price</th>
                  <th>Stock</th>
                  <th>Featured</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% if (products.length === 0) { %>
                  <tr>
                    <td colspan="7" class="text-center py-4 text-muted">No products found. <a href="/admin/products/add">Add one!</a></td>
                  </tr>
                <% } %>
                <% products.forEach(product => { %>
                  <tr>
                    <td>
                      <img src="/images/<%= product.image %>" alt="<%= product.name %>"
                        onerror="this.src='https://via.placeholder.com/50x50?text=IMG'"
                        style="width:50px; height:50px; object-fit:cover; border-radius:8px;">
                    </td>
                    <td class="fw-semibold"><%= product.name %></td>
                    <td><span class="badge bg-light text-primary border border-primary"><%= product.category %></span></td>
                    <td class="fw-bold text-primary">₹<%= product.price.toLocaleString() %></td>
                    <td>
                      <span class="badge <%= product.stock > 0 ? 'bg-success' : 'bg-danger' %>">
                        <%= product.stock %>
                      </span>
                    </td>
                    <td>
                      <% if (product.featured) { %>
                        <span class="badge bg-warning text-dark">⭐ Yes</span>
                      <% } else { %>
                        <span class="badge bg-light text-muted">No</span>
                      <% } %>
                    </td>
                    <td>
                      <a href="/admin/products/edit/<%= product._id %>" class="btn btn-sm btn-outline-primary me-1">
                        <i class="fas fa-edit"></i>
                      </a>
                      <a href="/admin/products/delete/<%= product._id %>" class="btn btn-sm btn-outline-danger"
                        onclick="return confirm('Delete this product?')">
                        <i class="fas fa-trash"></i>
                      </a>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
