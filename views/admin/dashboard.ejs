<%- include('../partials/header') %>

<div class="container-fluid py-4">
  <div class="row">
    <!-- Sidebar -->
    <div class="col-md-2">
      <div class="card border-0 shadow-sm">
        <div class="card-body p-3">
          <h6 class="fw-bold text-primary mb-3"><i class="fas fa-cog me-2"></i>Admin Panel</h6>
          <ul class="list-unstyled">
            <li class="mb-2"><a href="/admin" class="text-decoration-none text-dark fw-semibold"><i class="fas fa-tachometer-alt me-2 text-primary"></i>Dashboard</a></li>
            <li class="mb-2"><a href="/admin/products" class="text-decoration-none text-muted"><i class="fas fa-box me-2"></i>Products</a></li>
            <li class="mb-2"><a href="/admin/orders" class="text-decoration-none text-muted"><i class="fas fa-shopping-bag me-2"></i>Orders</a></li>
            <li class="mb-2"><a href="/admin/users" class="text-decoration-none text-muted"><i class="fas fa-users me-2"></i>Users</a></li>
            <li class="mb-2"><a href="/" class="text-decoration-none text-muted"><i class="fas fa-store me-2"></i>View Store</a></li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="col-md-10">
      <h4 class="fw-bold mb-4">Dashboard Overview</h4>

      <!-- Stats Cards -->
      <div class="row g-4 mb-4">
        <div class="col-md-3">
          <div class="card border-0 shadow-sm text-white" style="background: linear-gradient(135deg, #1a56a0, #0d3b7a);">
            <div class="card-body d-flex justify-content-between align-items-center">
              <div>
                <p class="mb-1 opacity-75 small">Total Products</p>
                <h2 class="fw-bold mb-0"><%= totalProducts %></h2>
              </div>
              <i class="fas fa-box fa-2x opacity-50"></i>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card border-0 shadow-sm text-white bg-success">
            <div class="card-body d-flex justify-content-between align-items-center">
              <div>
                <p class="mb-1 opacity-75 small">Total Users</p>
                <h2 class="fw-bold mb-0"><%= totalUsers %></h2>
              </div>
              <i class="fas fa-users fa-2x opacity-50"></i>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card border-0 shadow-sm text-white bg-warning">
            <div class="card-body d-flex justify-content-between align-items-center">
              <div>
                <p class="mb-1 opacity-75 small">Total Orders</p>
                <h2 class="fw-bold mb-0"><%= totalOrders %></h2>
              </div>
              <i class="fas fa-shopping-bag fa-2x opacity-50"></i>
            </div>
          </div>
        </div>
        <div class="col-md-3">
          <div class="card border-0 shadow-sm text-white bg-danger">
            <div class="card-body d-flex justify-content-between align-items-center">
              <div>
                <p class="mb-1 opacity-75 small">Total Revenue</p>
                <h2 class="fw-bold mb-0">₹<%= revenue.toLocaleString() %></h2>
              </div>
              <i class="fas fa-rupee-sign fa-2x opacity-50"></i>
            </div>
          </div>
        </div>
      </div>

      <!-- Recent Orders -->
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
          <h5 class="fw-bold mb-0">Recent Orders</h5>
          <a href="/admin/orders" class="btn btn-sm btn-outline-primary">View All</a>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>Order ID</th>
                  <th>Customer</th>
                  <th>Amount</th>
                  <th>Status</th>
                  <th>Date</th>
                </tr>
              </thead>
              <tbody>
                <% recentOrders.forEach(order => { %>
                  <tr>
                    <td><small class="fw-semibold">#<%= order._id.toString().slice(-8).toUpperCase() %></small></td>
                    <td><%= order.user ? order.user.name : 'N/A' %></td>
                    <td class="fw-bold text-primary">₹<%= order.totalAmount.toLocaleString() %></td>
                    <td>
                      <span class="badge
                        <%= order.status === 'Delivered' ? 'bg-success' :
                           order.status === 'Shipped' ? 'bg-info' :
                           order.status === 'Processing' ? 'bg-warning text-dark' :
                           order.status === 'Cancelled' ? 'bg-danger' : 'bg-secondary' %>">
                        <%= order.status %>
                      </span>
                    </td>
                    <td><small><%= new Date(order.createdAt).toLocaleDateString('en-IN') %></small></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
