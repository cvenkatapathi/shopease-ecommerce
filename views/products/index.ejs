<%- include('../partials/header') %>

<div class="container py-4">
  <div class="row">
    <!-- Sidebar Filter -->
    <div class="col-md-3 mb-4">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <h5 class="fw-bold mb-3"><i class="fas fa-filter me-2 text-primary"></i>Filters</h5>
          <form action="/products" method="GET">
            <% if (typeof search !== 'undefined' && search) { %>
              <input type="hidden" name="search" value="<%= search %>">
            <% } %>
            <div class="mb-3">
              <label class="form-label fw-semibold">Category</label>
              <% categories.forEach(cat => { %>
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="category" value="<%= cat %>"
                    <%= (typeof category !== 'undefined' && category === cat) ? 'checked' : '' %> id="cat-<%= cat %>">
                  <label class="form-check-label small" for="cat-<%= cat %>"><%= cat %></label>
                </div>
              <% }); %>
            </div>
            <div class="mb-3">
              <label class="form-label fw-semibold">Price Range</label>
              <input type="number" class="form-control form-control-sm mb-2" name="minPrice" placeholder="Min ₹" value="<%= typeof minPrice !== 'undefined' ? minPrice : '' %>">
              <input type="number" class="form-control form-control-sm" name="maxPrice" placeholder="Max ₹" value="<%= typeof maxPrice !== 'undefined' ? maxPrice : '' %>">
            </div>
            <div class="mb-3">
              <label class="form-label fw-semibold">Sort By</label>
              <select class="form-select form-select-sm" name="sort">
                <option value="">Latest</option>
                <option value="price-low" <%= (typeof sort !== 'undefined' && sort === 'price-low') ? 'selected' : '' %>>Price: Low to High</option>
                <option value="price-high" <%= (typeof sort !== 'undefined' && sort === 'price-high') ? 'selected' : '' %>>Price: High to Low</option>
                <option value="rating" <%= (typeof sort !== 'undefined' && sort === 'rating') ? 'selected' : '' %>>Top Rated</option>
              </select>
            </div>
            <button type="submit" class="btn btn-primary btn-sm w-100">Apply Filters</button>
            <a href="/products" class="btn btn-outline-secondary btn-sm w-100 mt-2">Clear All</a>
          </form>
        </div>
      </div>
    </div>

    <!-- Products Grid -->
    <div class="col-md-9">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="fw-bold mb-0">
          <% if (typeof search !== 'undefined' && search) { %>
            Results for "<%= search %>" (<%= products.length %> found)
          <% } else { %>
            All Products (<%= products.length %>)
          <% } %>
        </h5>
      </div>

      <% if (products.length === 0) { %>
        <div class="text-center py-5">
          <i class="fas fa-search fa-4x text-muted mb-3"></i>
          <h5 class="text-muted">No products found</h5>
          <a href="/products" class="btn btn-primary mt-3">View All Products</a>
        </div>
      <% } else { %>
        <div class="row g-4">
          <% products.forEach(product => { %>
            <div class="col-6 col-lg-4">
              <%- include('../partials/product-card', { product }) %>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
